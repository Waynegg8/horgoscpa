{
  "version": "3.0",
  "description": "智能文档处理器v3.0统一配置",
  "last_updated": "2024-12-19",
  
  "processing_modes": {
    "basic": {
      "description": "基础模式：只进行Word到HTML转换",
      "enabled_features": [
        "word_extraction",
        "basic_html_generation"
      ],
      "quality_requirements": {
        "min_content_retention": 0.75,
        "require_structure_validation": false,
        "enable_seo_optimization": false
      }
    },
    "standard": {
      "description": "标准模式：包含SEO优化和基本验证",
      "enabled_features": [
        "word_extraction",
        "smart_title_extraction",
        "basic_html_generation",
        "seo_optimization",
        "basic_validation"
      ],
      "quality_requirements": {
        "min_content_retention": 0.8,
        "require_structure_validation": true,
        "enable_seo_optimization": true
      }
    },
    "enhanced": {
      "description": "增强模式：智能高亮、分类和内容分析",
      "enabled_features": [
        "word_extraction",
        "document_classification",
        "smart_title_extraction", 
        "smart_highlighting",
        "seo_optimization",
        "content_validation",
        "quality_scoring"
      ],
      "quality_requirements": {
        "min_content_retention": 0.85,
        "require_structure_validation": true,
        "enable_seo_optimization": true,
        "require_highlight_validation": true
      }
    },
    "premium": {
      "description": "高级模式：全功能包含质量评分和严格验证",
      "enabled_features": [
        "word_extraction",
        "document_classification",
        "smart_title_extraction",
        "smart_highlighting",
        "seo_optimization", 
        "content_validation",
        "quality_scoring",
        "detailed_reporting",
        "advanced_analytics"
      ],
      "quality_requirements": {
        "min_content_retention": 0.9,
        "require_structure_validation": true,
        "enable_seo_optimization": true,
        "require_highlight_validation": true,
        "min_quality_score": 80,
        "fail_on_validation_error": true
      }
    }
  },

  "document_types": {
    "tax_analysis": {
      "display_name": "税务分析",
      "keywords": ["税法", "修正", "制度", "变革", "分析", "应纳", "免税"],
      "patterns": ["第\\d+条", "\\d+萬元", "\\d+%"],
      "special_processing": {
        "enable_calculation_detection": true,
        "highlight_tax_amounts": true,
        "extract_regulation_references": true
      }
    },
    "tax_schedule": {
      "display_name": "税务时程",
      "keywords": ["申报", "缴纳", "期限", "截止", "月份"],
      "patterns": ["\\d{1,2}月\\d{1,2}日", "前\\d+日"],
      "special_processing": {
        "highlight_deadlines": true,
        "extract_date_ranges": true,
        "calendar_integration": true
      }
    },
    "policy_update": {
      "display_name": "政策更新", 
      "keywords": ["政策", "新制", "公告", "通知", "实施"],
      "patterns": ["自\\d+年\\d+月\\d+日起"],
      "special_processing": {
        "track_implementation_dates": true,
        "compare_old_vs_new": true
      }
    },
    "general": {
      "display_name": "一般文章",
      "keywords": [],
      "patterns": [],
      "special_processing": {
        "enable_basic_highlighting": true
      }
    }
  },

  "number_recognition": {
    "patterns": {
      "currency": {
        "regex": "\\d+(?:,\\d{3})*(?:\\.\\d+)?(?:萬?元|萬|億|千)",
        "importance_base": 15,
        "examples": ["1,000萬元", "281.05萬元", "5,000元", "1.5億"]
      },
      "percentage": {
        "regex": "\\d+(?:\\.\\d+)?%",
        "importance_base": 12,
        "examples": ["15%", "3.5%", "0.85%"]
      },
      "decimal_number": {
        "regex": "\\d+(?:,\\d{3})*\\.\\d+",
        "importance_base": 10,
        "examples": ["281.05", "1,209.35", "3.14"]
      },
      "date": {
        "regex": "\\d{1,2}月\\d{1,2}日",
        "importance_base": 10,
        "examples": ["1月1日", "12月31日"]
      },
      "law_reference": {
        "regex": "第\\d+[条條](?:第\\d+[项項款])?",
        "importance_base": 8,
        "examples": ["第15条", "第1项", "第15条第1项"]
      }
    },
    "importance_keywords": {
      "final_result": {
        "keywords": ["应纳", "應納", "总额", "總額", "合计", "合計", "最终", "最終"],
        "weight": 25
      },
      "key_data": {
        "keywords": ["免税", "免稅", "扣除", "减免", "減免", "门槛", "門檻"],
        "weight": 20
      },
      "important_ref": {
        "keywords": ["截止", "期限", "前", "内", "內", "规定", "規定"],
        "weight": 15
      },
      "auxiliary": {
        "keywords": ["举例", "舉例", "参考", "參考", "说明", "說明"],
        "weight": 5
      }
    }
  },

  "highlighting": {
    "priorities": {
      "final_result": 1,
      "key_deadline": 2,
      "important_amount": 3,
      "regulation_reference": 4,
      "auxiliary_data": 5
    },
    "rules": {
      "final_result": {
        "patterns": [
          "应纳.*?税.*?[:：]\\s*\\d+(?:,\\d{3})*(?:\\.\\d+)?.*?[萬万]?元",
          "總.*?税.*?额.*?[:：]\\s*\\d+(?:,\\d{3})*(?:\\.\\d+)?.*?[萬万]?元"
        ],
        "css_class": "highlight-final-result",
        "style": "background: linear-gradient(135deg, #ffeb3b, #ffc107); font-weight: bold; padding: 3px 6px; border-radius: 4px;",
        "priority_weight": 100
      },
      "calculation_formula": {
        "patterns": [
          "\\d+(?:,\\d{3})*(?:\\.\\d+)?.*?[萬万]?元\\s*[×x]\\s*\\d+(?:\\.\\d+)?%\\s*[-−]\\s*\\d+(?:,\\d{3})*(?:\\.\\d+)?.*?[萬万]?元\\s*=\\s*\\d+(?:,\\d{3})*(?:\\.\\d+)?.*?[萬万]?元"
        ],
        "css_class": "highlight-calculation",
        "style": "background: #e3f2fd; border: 2px solid #2196f3; padding: 2px 4px; border-radius: 3px;",
        "priority_weight": 90
      },
      "key_deadline": {
        "patterns": [
          "\\d{1,2}月\\d{1,2}日(?:前|截止|之前)",
          "前\\d+[日天]",
          "截止.*?\\d{1,2}月\\d{1,2}日"
        ],
        "css_class": "highlight-deadline",
        "style": "background: #f44336; color: white; padding: 2px 5px; border-radius: 3px; font-weight: bold;",
        "priority_weight": 85
      },
      "important_amount": {
        "patterns": [
          "(?:免税额|免稅額|扣除额|扣除額).*?[:：]\\s*\\d+(?:,\\d{3})*(?:\\.\\d+)?.*?[萬万]?元",
          "\\d+(?:,\\d{3})*(?:\\.\\d+)?[萬万億亿]元(?!\\s*[×x÷/])"
        ],
        "css_class": "highlight-amount",
        "style": "background: #4caf50; color: white; padding: 2px 4px; border-radius: 3px;",
        "priority_weight": 70
      },
      "regulation_reference": {
        "patterns": [
          "第\\d+[条條](?:第\\d+[项項款])?",
          "[法規规].*?第\\d+[条條]"
        ],
        "css_class": "highlight-regulation",
        "style": "background: #2196f3; color: white; padding: 2px 4px; border-radius: 3px;",
        "priority_weight": 60
      }
    },
    "context_enhancers": {
      "tax_calculation": {
        "context_keywords": ["应纳", "應納", "税额", "稅額", "计算", "計算"],
        "enhancement_factor": 1.5
      },
      "deadline_context": {
        "context_keywords": ["截止", "期限", "前", "申报", "申報", "缴纳", "繳納"],
        "enhancement_factor": 1.3
      }
    }
  },

  "seo_optimization": {
    "title_optimization": {
      "max_length": 50,
      "min_length": 15,
      "include_year": true,
      "include_keywords": true
    },
    "url_generation": {
      "max_length": 55,
      "include_date_prefix": true,
      "use_semantic_keywords": true,
      "stop_words": [
        "的", "和", "或", "但", "而且", "然而", "因此", "所以", "由於",
        "of", "and", "or", "but", "the", "a", "an", "in", "on", "at", "to", "for"
      ]
    },
    "meta_generation": {
      "description_length": {
        "min": 120,
        "max": 160
      },
      "keywords_count": {
        "min": 3,
        "max": 5
      }
    }
  },

  "quality_scoring": {
    "weights": {
      "content_completeness": 0.3,
      "seo_score": 0.2,
      "readability": 0.2,
      "structure": 0.15,
      "highlighting": 0.15
    },
    "thresholds": {
      "excellent": 90,
      "good": 80,
      "acceptable": 70,
      "needs_improvement": 60
    },
    "specific_checks": {
      "decimal_number_preservation": {
        "enabled": true,
        "weight": 10,
        "description": "检查小数点数字是否完整保留"
      },
      "highlight_coverage": {
        "enabled": true,
        "weight": 15,
        "min_coverage": 0.6,
        "description": "检查重要内容的高亮覆盖率"
      },
      "structure_completeness": {
        "enabled": true,
        "weight": 20,
        "required_elements": ["h1", "h2", "article"],
        "description": "检查HTML结构完整性"
      }
    }
  },

  "validation": {
    "content_retention": {
      "min_ratio": 0.85,
      "check_decimal_numbers": true,
      "check_important_keywords": true
    },
    "structure_validation": {
      "required_elements": ["article", "h1"],
      "check_heading_hierarchy": true,
      "validate_semantic_markup": true
    },
    "highlight_validation": {
      "min_coverage": 0.5,
      "check_decimal_highlighting": true,
      "validate_priority_assignment": true
    }
  },

  "github_actions": {
    "workflow_mapping": {
      "content_operations": {
        "process_word": "处理Word文档",
        "update_json": "更新JSON文件", 
        "validate_content": "验证内容",
        "force_scan": "强制扫描HTML文章",
        "all_content": "所有内容相关操作"
      },
      "maintenance_operations": {
        "handle_deletion": "处理文章删除",
        "update_sitemap": "更新站点地图",
        "update_dictionary": "更新翻译字典",
        "all_maintenance": "所有维护操作"
      },
      "media_publishing": {
        "update_videos": "更新视频数据",
        "publish_scheduled": "发布排程文章",
        "all_media": "所有媒体操作"
      },
      "system_config": {
        "basic_processor": "使用基础处理器",
        "enhanced_processor": "使用增强处理器",
        "strict_validation": "严格验证模式",
        "force_mode": "强制处理模式"
      }
    },
    "trigger_mappings": {
      "schedule": {
        "default_operations": {
          "update_sitemap": true,
          "update_dictionary": true,
          "publish_scheduled": true
        }
      },
      "push": {
        "default_operations": {
          "process_word": true,
          "update_json": true,
          "update_sitemap": true
        }
      },
      "repository_dispatch": {
        "action_mappings": {
          "delete-article": {"handle_deletion": true},
          "upload-article": {"process_word": true, "update_json": true},
          "scan-articles": {"force_scan": true, "update_json": true},
          "update-video": {"update_videos": true},
          "intelligent-process": {"process_word": true, "validate_content": true, "use_enhanced_processor": true}
        }
      }
    }
  },

  "file_paths": {
    "default_dirs": {
      "word_dir": "word-docs",
      "output_dir": "blog",
      "assets_dir": "assets",
      "processed_dir": "word-docs/processed",
      "reports_dir": "reports",
      "logs_dir": "logs"
    },
    "data_files": {
      "translation_dict": "assets/data/translation_dict.json",
      "processed_files": "assets/data/processed_files.json",
      "blog_posts": "assets/data/blog-posts.json",
      "blog_index": "assets/data/blog-index.json"
    }
  },

  "logging": {
    "levels": {
      "debug": "DEBUG",
      "info": "INFO", 
      "warning": "WARNING",
      "error": "ERROR"
    },
    "formatters": {
      "detailed": "<green>{time:YYYY-MM-DD HH:mm:ss}</green> | <level>{level: <8}</level> | <cyan>{name}</cyan>:<cyan>{function}</cyan>:<cyan>{line}</cyan> - <level>{message}</level>",
      "simple": "{time:HH:mm:ss} | {level} | {message}"
    },
    "retention": {
      "rotation": "1 day",
      "retention_days": 30
    }
  },

  "performance": {
    "batch_processing": {
      "max_concurrent": 3,
      "chunk_size": 5,
      "timeout_seconds": 300
    },
    "memory_limits": {
      "max_document_size_mb": 50,
      "max_html_size_mb": 20
    }
  },

  "experimental_features": {
    "ai_content_analysis": {
      "enabled": false,
      "description": "使用AI进行内容分析和摘要生成"
    },
    "auto_translation": {
      "enabled": false,
      "description": "自动翻译功能"
    },
    "advanced_seo_scoring": {
      "enabled": false,
      "description": "高级SEO评分算法"
    }
  }
}